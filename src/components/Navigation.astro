---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Equipment', href: '/equipment/' },
  { label: 'Services', href: '/services/' },
  { label: 'Service Areas', href: '/service-areas/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
];
---

<header
  id="site-header"
  role="banner"
  class="fixed top-0 left-0 right-0 z-[9998] text-white"
  style="background-color: #000000; border-bottom: 1px solid rgba(207,163,64,0.25);"
>
  <nav role="navigation" aria-label="Main navigation" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between pt-2 md:pt-3">
      <!-- Logo -->
      <a href="/" aria-label="CM Equipment Hire — Home" class="flex items-center focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded-lg">
        <img
          src="/assets/logo.png"
          alt="CM Equipment Hire"
          class="h-21 md:h-27 w-auto -mb-2"
          loading="eager"
          style="max-width: 400px;"
        />
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex lg:items-center lg:gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-lg px-3 py-2 text-sm font-medium text-white hover:bg-primary-light transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-primary"
          >
            {link.label}
          </a>
        ))}
        <!-- Desktop phone CTA -->
        <a
          href="tel:0487558563"
          class="ml-4 inline-flex items-center gap-2 rounded-lg bg-accent/50 border-2 border-accent px-4 py-2 text-sm font-bold text-primary hover:bg-accent-hover transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-primary min-h-[48px]"
        >
          Call Now
        </a>
      </div>

      <!-- Mobile: phone + hamburger -->
      <div class="flex items-center gap-3 lg:hidden">
        <a
          href="tel:0487558563"
          class="inline-flex items-center rounded-lg bg-accent/50 border-2 border-accent px-3 py-2 text-sm font-bold text-primary hover:bg-accent-hover transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-primary min-h-[48px]"
          aria-label="Call Now"
        >
          Call Now
        </a>
        <button
          type="button"
          id="mobile-menu-btn"
          class="inline-flex h-12 w-12 items-center justify-center rounded-lg text-white hover:bg-primary-light transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-primary"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open menu"
        >
          <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-white/10 pb-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block rounded-lg px-3 py-3 text-base font-medium text-white hover:bg-primary-light transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-primary min-h-[48px] flex items-center"
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  menuBtn?.addEventListener('click', () => {
    const isOpen = menuBtn.getAttribute('aria-expanded') === 'true';
    menuBtn.setAttribute('aria-expanded', String(!isOpen));
    menuBtn.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
    mobileMenu?.classList.toggle('hidden');
    hamburgerIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
