---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

const categoryDisplayNames: Record<string, string> = {
  'excavators': 'Excavators',
  'dump-trucks': 'Dump Trucks',
  'wheel-loaders': 'Wheel Loaders',
  'graders': 'Graders',
  'water-carts': 'Water Carts',
  'rollers': 'Rollers',
};

export async function getStaticPaths() {
  const equipment = await getCollection('equipment');

  return equipment.map((item) => ({
    params: {
      category: item.data.category,
      slug: item.data.slug,
    },
    props: {
      machine: item,
      relatedEquipment: equipment
        .filter(
          (e) =>
            e.data.category === item.data.category &&
            e.data.slug !== item.data.slug
        )
        .sort((a, b) => a.data.sortOrder - b.data.sortOrder),
    },
  }));
}

const { machine, relatedEquipment } = Astro.props;
const { Content } = await render(machine);
const data = machine.data;
const category = data.category;
const categoryDisplay = categoryDisplayNames[category] || category;

const specs: { label: string; value: string | undefined }[] = [
  { label: 'Year', value: data.year?.toString() },
  { label: 'Operating Weight', value: data.operatingWeight },
  { label: 'Engine', value: data.engine },
  { label: 'Payload', value: data.payload },
  { label: 'Max Dig Depth', value: data.maxDigDepth },
  { label: 'Bucket Capacity', value: data.bucketCapacity },
  { label: 'Heaped Capacity', value: data.heapedCapacity },
  { label: 'Blade Width', value: data.bladeWidth },
  { label: 'Power', value: data.power },
];
const visibleSpecs = specs.filter((s) => s.value);
---

<BaseLayout
  title={data.metaTitle}
  description={data.metaDescription}
>
  <script slot="schemaMarkup" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": data.name,
    "description": data.metaDescription,
    "brand": { "@type": "Brand", "name": data.brand },
    "category": categoryDisplay,
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "areaServed": { "@type": "State", "name": "Western Australia" }
    }
  })} />
  <script slot="schemaMarkup" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cmequipmenthire.com.au" },
      { "@type": "ListItem", "position": 2, "name": "Equipment", "item": "https://cmequipmenthire.com.au/equipment/" },
      { "@type": "ListItem", "position": 3, "name": data.name, "item": `https://cmequipmenthire.com.au/equipment/${category}/${data.slug}/` }
    ]
  })} />

  <section class="bg-surface">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex flex-wrap items-center gap-1 text-sm font-body text-text-muted">
          <li><a href="/" class="hover:text-accent focus-visible:ring-2 focus-visible:ring-accent rounded">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/equipment/" class="hover:text-accent focus-visible:ring-2 focus-visible:ring-accent rounded">Equipment</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-text font-bold" aria-current="page">{data.name}</li>
        </ol>
      </nav>

      <h1 class="font-display text-3xl lg:text-5xl font-bold text-primary mb-8">
        {data.name} &mdash; Available for Hire in WA
      </h1>

      <!-- Hero image -->
      <div class="aspect-video bg-gradient-to-br from-primary-light to-primary rounded-lg mb-12 overflow-hidden">
        {data.heroImage ? (
          <Image
            src={data.heroImage}
            alt={`${data.name} available for hire in Western Australia`}
            class="w-full h-full object-cover"
            widths={[400, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 100vw"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-text-muted text-sm font-body">
            [Photo coming soon]
          </div>
        )}
      </div>

      <div class="lg:grid lg:grid-cols-3 lg:gap-12">
        <div class="lg:col-span-2">
          {visibleSpecs.length > 0 && (
            <div class="mb-10">
              <h2 class="font-display text-2xl font-bold text-primary mb-4">Specifications</h2>
              <table class="w-full text-left font-body">
                <tbody>
                  {visibleSpecs.map((spec, i) => (
                    <tr class={i % 2 === 0 ? 'bg-surface' : 'bg-white'}>
                      <td class="px-4 py-3 text-sm font-bold text-text">{spec.label}</td>
                      <td class="px-4 py-3 text-sm text-text-muted">{spec.value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          <div class="mb-10">
            <h2 class="font-display text-2xl font-bold text-primary mb-4">Hire Options</h2>
            <div class="flex flex-wrap gap-3">
              {data.hireTypes.map((type: string) => (
                <span class="inline-flex items-center rounded-lg bg-accent px-4 py-2 text-sm font-bold text-primary">
                  {type === 'wet' ? 'Wet Hire' : 'Dry Hire'}
                </span>
              ))}
            </div>
          </div>

          {data.idealFor && data.idealFor.length > 0 && (
            <div class="mb-10">
              <h2 class="font-display text-2xl font-bold text-primary mb-4">Ideal For</h2>
              <ul class="space-y-2">
                {data.idealFor.map((item: string) => (
                  <li class="flex items-start gap-3">
                    <svg class="h-5 w-5 flex-shrink-0 text-accent mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-text font-body">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="mb-10">
            <h2 class="font-display text-2xl font-bold text-primary mb-4">About This Machine</h2>
            <div class="prose prose-lg max-w-none font-body text-text-muted leading-relaxed">
              <Content />
            </div>
          </div>
        </div>

        <div class="lg:col-span-1">
          <div class="sticky top-24 bg-white border border-border rounded-lg shadow-sm p-6 lg:p-8">
            <h3 class="font-display text-xl font-bold text-primary mb-6">Enquire About This Machine</h3>
            <a
              href="tel:0487558563"
              class="flex items-center justify-center rounded-lg bg-accent px-6 py-4 text-lg font-bold text-primary hover:bg-accent-hover transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 min-h-[48px] w-full mb-4"
            >
              <svg class="h-5 w-5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              0487 558 563
            </a>
            <a
              href={`/contact/?machine=${data.slug}`}
              class="flex items-center justify-center text-accent font-bold text-sm hover:underline focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 rounded"
            >
              Or fill out our quote form &rarr;
            </a>
          </div>
        </div>
      </div>

      {relatedEquipment.length > 0 && (
        <div class="mt-16 pt-12 border-t border-border">
          <h2 class="font-display text-2xl font-bold text-primary mb-8">Other Equipment</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {relatedEquipment.map((item) => (
              <a
                href={`/equipment/${item.data.category}/${item.data.slug}/`}
                class="group block bg-white border border-border rounded-lg shadow-sm overflow-hidden hover:shadow-md hover:scale-[1.02] transition-all duration-300 focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
              >
                <div class="aspect-[4/3] bg-gradient-to-br from-primary-light to-primary overflow-hidden">
                  {item.data.heroImage ? (
                    <Image
                      src={item.data.heroImage}
                      alt={`${item.data.name} available for hire`}
                      class="w-full h-full object-cover"
                      widths={[400]}
                      sizes="33vw"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-text-muted text-sm font-body">
                      [Photo coming soon]
                    </div>
                  )}
                </div>
                <div class="p-6">
                  <h3 class="font-display text-lg font-bold text-primary mb-2">{item.data.name}</h3>
                  {item.data.year && <p class="text-text-muted text-sm font-body mb-1">{item.data.year} model</p>}
                  {item.data.operatingWeight && <p class="text-text-muted text-sm font-body mb-1">Operating Weight: {item.data.operatingWeight}</p>}
                  {item.data.payload && <p class="text-text-muted text-sm font-body mb-1">Payload: {item.data.payload}</p>}
                  <div class="flex flex-wrap gap-2 mt-3 mb-4">
                    {item.data.hireTypes.map((type: string) => (
                      <span class="inline-block border border-accent text-accent text-xs font-bold px-2 py-1 rounded">
                        {type === 'wet' ? 'Wet Hire' : 'Dry Hire'}
                      </span>
                    ))}
                  </div>
                  <span class="text-accent font-bold text-sm group-hover:underline">View Details &rarr;</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
