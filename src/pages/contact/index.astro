---
import BaseLayout from '@/layouts/BaseLayout.astro';

const serviceOptions = [
  'Dam Construction',
  'Drainage & Contours',
  'Land Clearing',
  'Civil Earthworks',
  'Equipment Hire — Wet',
  'Equipment Hire — Dry',
  'Other',
];

const timingOptions = [
  'ASAP',
  'Within 2 weeks',
  'Within 1 month',
  'Just planning ahead',
];
---

<BaseLayout
  title="Contact CM Equipment Hire | Get a Quote"
  description="Get a quote for equipment hire across the Wheatbelt and WA. Call 0487 558 563 or fill out our online form."
>
  <script slot="schemaMarkup" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://cmequipmenthire.com.au"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Contact",
        "item": "https://cmequipmenthire.com.au/contact"
      }
    ]
  })} />

  <!-- Header -->
  <section class="bg-primary text-white -mt-16 pt-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl leading-tight mb-4">Get in Touch</h1>
      <p class="text-lg text-white/80 font-body max-w-2xl">
        Tell us about your project and we'll get back to you with a quote — usually within 2 hours.
      </p>
    </div>
  </section>

  <!-- Main content -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">

      <!-- Left — Contact Form -->
      <div class="lg:col-span-3">
        <div id="form-container">
          <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
            <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
            <input type="hidden" name="subject" value="New Equipment Enquiry — CM Equipment Hire" />
            <input type="hidden" name="redirect" value="false" />
            <input type="checkbox" name="botcheck" class="hidden" />

            <!-- Name -->
            <div>
              <label for="name" class="block font-body font-medium text-text mb-1">Name <span class="text-accent">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full border border-border rounded-lg p-3 font-body text-text bg-white focus:ring-2 focus:ring-accent focus:border-accent focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none transition-shadow"
              />
            </div>

            <!-- Company/Farm Name -->
            <div>
              <label for="company" class="block font-body font-medium text-text mb-1">Company/Farm Name</label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full border border-border rounded-lg p-3 font-body text-text bg-white focus:ring-2 focus:ring-accent focus:border-accent focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none transition-shadow"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block font-body font-medium text-text mb-1">Email <span class="text-accent">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full border border-border rounded-lg p-3 font-body text-text bg-white focus:ring-2 focus:ring-accent focus:border-accent focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none transition-shadow"
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="phone" class="block font-body font-medium text-text mb-1">Phone <span class="text-accent">*</span></label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full border border-border rounded-lg p-3 font-body text-text bg-white focus:ring-2 focus:ring-accent focus:border-accent focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none transition-shadow"
              />
            </div>

            <!-- Service Interest -->
            <div>
              <label for="service" class="block font-body font-medium text-text mb-1">Service Interest</label>
              <select
                id="service"
                name="service"
                class="w-full border border-border rounded-lg p-3 font-body text-text bg-white focus:ring-2 focus:ring-accent focus:border-accent focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none transition-shadow"
              >
                <option value="">Select a service...</option>
                {serviceOptions.map((opt) => (
                  <option value={opt}>{opt}</option>
                ))}
              </select>
            </div>

            <!-- Project Location -->
            <div>
              <label for="location" class="block font-body font-medium text-text mb-1">Project Location <span class="text-accent">*</span></label>
              <input
                type="text"
                id="location"
                name="location"
                required
                placeholder="e.g. Corrigin, Narrogin, Perth"
                class="w-full border border-border rounded-lg p-3 font-body text-text bg-white focus:ring-2 focus:ring-accent focus:border-accent focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none transition-shadow placeholder:text-text-muted"
              />
            </div>

            <!-- Approximate Timing -->
            <div>
              <label for="timing" class="block font-body font-medium text-text mb-1">Approximate Timing</label>
              <select
                id="timing"
                name="timing"
                class="w-full border border-border rounded-lg p-3 font-body text-text bg-white focus:ring-2 focus:ring-accent focus:border-accent focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none transition-shadow"
              >
                <option value="">Select timing...</option>
                {timingOptions.map((opt) => (
                  <option value={opt}>{opt}</option>
                ))}
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block font-body font-medium text-text mb-1">Message</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full border border-border rounded-lg p-3 font-body text-text bg-white focus:ring-2 focus:ring-accent focus:border-accent focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none transition-shadow resize-y"
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full bg-accent text-primary font-body font-bold text-lg px-6 py-4 rounded-lg hover:bg-accent-hover transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
            >
              Send Enquiry
            </button>
          </form>
        </div>

        <!-- Success message -->
        <div id="success-message" class="hidden bg-success/10 border border-success rounded-lg p-8 text-center">
          <svg class="w-12 h-12 text-success mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <p class="font-display text-xl text-primary mb-2">Enquiry Sent</p>
          <p class="font-body text-text text-lg">Thanks — we'll be in touch within 2 hours.</p>
        </div>

        <!-- Error message -->
        <div id="error-message" class="hidden bg-red-50 border border-red-300 rounded-lg p-6 mt-4">
          <p class="font-body text-red-800">
            Something went wrong. Please call us directly at
            <a href="tel:0487558563" class="font-bold underline">0487 558 563</a>.
          </p>
        </div>
      </div>

      <!-- Right — Direct Contact -->
      <div class="lg:col-span-2">
        <div class="bg-white border border-border rounded-lg p-6 lg:p-8 space-y-8">
          <!-- Phone -->
          <div>
            <h2 class="font-body font-medium text-text-muted text-sm uppercase tracking-wider mb-2">Phone</h2>
            <a href="tel:0487558563" class="text-2xl font-bold text-accent font-body hover:text-accent-hover transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 rounded">
              0487 558 563
            </a>
          </div>

          <!-- Email -->
          <div>
            <h2 class="font-body font-medium text-text-muted text-sm uppercase tracking-wider mb-2">Email</h2>
            <a href="mailto:cmequipmenthire@gmail.com" class="font-body text-text hover:text-accent transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 rounded">
              cmequipmenthire@gmail.com
            </a>
          </div>

          <!-- Hours -->
          <div>
            <h2 class="font-body font-medium text-text-muted text-sm uppercase tracking-wider mb-2">Hours</h2>
            <p class="font-body text-text">Available 24/7</p>
            <p class="font-body text-text-muted text-sm mt-1">Call us any time</p>
          </div>

          <!-- Location / Map -->
          <div>
            <h2 class="font-body font-medium text-text-muted text-sm uppercase tracking-wider mb-2">Location</h2>
            <p class="font-body text-text mb-3">418 Corry Rd, Bulyee WA 6306</p>
            <!-- TODO: Replace with Google Maps iframe -->
            <div class="aspect-video bg-surface border border-border rounded-lg flex items-center justify-center text-text-muted text-sm font-body">
              [Google Maps placeholder]
            </div>
          </div>

          <!-- After-hours -->
          <div class="bg-surface border-l-4 border-accent rounded-lg p-4">
            <p class="font-body text-text text-sm leading-relaxed">
              Need equipment urgently? Call us — we'll do our best to make it happen.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const form = document.getElementById('contact-form');
    const formContainer = document.getElementById('form-container');
    const successMessage = document.getElementById('success-message');
    const errorMessage = document.getElementById('error-message');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData
        });
        const data = await response.json();
        if (data.success) {
          formContainer.classList.add('hidden');
          successMessage.classList.remove('hidden');
        } else {
          errorMessage.classList.remove('hidden');
        }
      } catch {
        errorMessage.classList.remove('hidden');
      }
    });
  </script>
</BaseLayout>
